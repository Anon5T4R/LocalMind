{
  "name": "taylormind",
  "version": "0.1.0",
  "description": "AI-powered mind mapping (XMind/SimpleMind clone) with local & remote LLMs",
  "main": "./out/main/index.js",
  "author": "joaof",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/patch-deps.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.taylormind.app",
    "productName": "TaylorMind",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "TaylorMind-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@xyflow/react": "^12.3.5",
    "electron-store": "^8.2.0",
    "nanoid": "^5.0.9",
    "node-llama-cpp": "^3.3.0",
    "openai": "^4.77.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^29.4.6",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
